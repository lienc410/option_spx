{
  "_doc": "SPEC-117.6 heartbeat registry. kind: keepalive=must have live PID; calendar=last exit must be in allow_exit. freshness: file must be fresh per rule — 'trading_day'=mtime today when today is a NYSE trading day (monitor runs 17:30 ET, after all producers); 'daily_26h'=mtime within 26h regardless of trading day. path relative to ~/SPX_strat unless absolute. New jobs MUST be added here (heartbeat asserts registry covers all com.spxstrat.* labels it sees).",
  "jobs": [
    {"label": "com.spxstrat.web",                  "kind": "keepalive", "allow_exit": [0, -15]},
    {"label": "com.spxstrat.bot",                  "kind": "keepalive", "allow_exit": [0, -15]},
    {"label": "com.spxstrat.cloudflared",          "kind": "keepalive", "allow_exit": [0, -15, 11]},
    {"label": "com.spxstrat.cloudflared-b",        "kind": "keepalive", "allow_exit": [0, -15, 11]},
    {"label": "com.spxstrat.web_nightly_restart",  "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.daily_snapshot",       "kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/daily_snapshot.jsonl", "rule": "trading_day"}},
    {"label": "com.spxstrat.refresh_backtest",     "kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/backtest_stats_cache.json", "rule": "daily_26h"}},
    {"label": "com.spxstrat.signal_settling",      "kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/q019_settling_state.json", "rule": "trading_day"}},
    {"label": "com.spxstrat.greek_attribution",    "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.q041_collect",         "kind": "calendar",  "allow_exit": [0, 1],
     "freshness": {"path": "data/q041_chains/{today}/SPX.parquet", "rule": "trading_day"},
     "note": "exit 1 = partial symbol errors; SPX/QQQ hard-fail already telegrams via SPEC-114"},
    {"label": "com.spxstrat.q041_chain_sanity",    "kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/q041_chain_sanity_daily.jsonl", "rule": "trading_day"}},
    {"label": "com.spxstrat.q041_t2_paper_signals","kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/q041_paper_log.jsonl", "rule": "trading_day"}},
    {"label": "com.spxstrat.q041_t3_earnings_check","kind": "calendar", "allow_exit": [0]},
    {"label": "com.spxstrat.q085_s2bps",           "kind": "calendar",  "allow_exit": [0],
     "freshness": {"path": "data/q085_skew_monitor.jsonl", "rule": "trading_day"}},
    {"label": "com.spxstrat.q042_executor",        "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.q042_history_refresh", "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.etrade_keepalive",     "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.etrade_refresh",       "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.etrade_token_renew",   "kind": "calendar",  "allow_exit": [0],
     "note": "exit 1 = token already expired at 23:30 (PM did not re-auth that day) — alert is correct"},
    {"label": "com.spxstrat.schwab_refresh",       "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.fundexit.refresh",     "kind": "calendar",  "allow_exit": [0]},
    {"label": "com.spxstrat.ops_heartbeat",        "kind": "self",      "allow_exit": [0]},
    {"label": "LOCAL:com.spxstrat.local_backup_pull", "kind": "marker",
     "freshness": {"path": "data/.last_backup_pull", "rule": "daily_26h"},
     "note": "SPEC-117.1 L1 backup runs on the local machine at 05:00; it touches this marker on oldair after each successful pull"}
  ]
}
